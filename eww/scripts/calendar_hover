#!/usr/bin/env bash
# Calendar hover handler

LOCK_FILE="/tmp/eww_calendar.lock"

show_calendar() {
    if [ ! -f "$LOCK_FILE" ]; then
        touch "$LOCK_FILE"
        eww open calendar 2>/dev/null
    fi
}

hide_calendar() {
    if [ -f "$LOCK_FILE" ]; then
        rm -f "$LOCK_FILE"
        eww close calendar 2>/dev/null
    fi
}

case "$1" in
    show)
        show_calendar
        ;;
    hide)
        hide_calendar
        ;;
    toggle)
        if [ -f "$LOCK_FILE" ]; then
            hide_calendar
        else
            show_calendar
        fi
        ;;
esac
