#!/usr/bin/env bash
# Calendar hover handler

DIR="$(dirname "$(realpath "$0")")"
EWW_CONFIG_DIR="${EWW_CONFIG_DIR:-$(realpath "$DIR/..")}"

eww_cmd() {
    eww --config "$EWW_CONFIG_DIR" "$@"
}

LOCK_FILE="/tmp/eww_calendar.lock"

show_calendar() {
    if [ ! -f "$LOCK_FILE" ]; then
        touch "$LOCK_FILE"
        eww_cmd open calendar 2>/dev/null
    fi
}

hide_calendar() {
    if [ -f "$LOCK_FILE" ]; then
        rm -f "$LOCK_FILE"
        eww_cmd close calendar 2>/dev/null
    fi
}

case "$1" in
    show)
        show_calendar
        ;;
    hide)
        hide_calendar
        ;;
    toggle)
        if [ -f "$LOCK_FILE" ]; then
            hide_calendar
        else
            show_calendar
        fi
        ;;
esac
