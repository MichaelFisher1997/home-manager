#!/usr/bin/env bash

LAT="53.49"
LON="-2.08"
LOCATION="Ashton-Under-Lyne"
CACHE_FILE="/tmp/eww_weather_data.json"
CACHE_AGE=900

refresh_cache() {
  if [ ! -f "$CACHE_FILE" ] || [ $(( $(date +%s) - $(stat -c %Y "$CACHE_FILE" 2>/dev/null || echo 0) )) -gt $CACHE_AGE ]; then
    curl -s "https://api.open-meteo.com/v1/forecast?latitude=${LAT}&longitude=${LON}&daily=weathercode,temperature_2m_max,temperature_2m_min,precipitation_sum&current_weather=true&timezone=Europe%2FLondon&forecast_days=5" \
      -o "$CACHE_FILE" 2>/dev/null
  fi
}

read_data() {
  refresh_cache
  cat "$CACHE_FILE" 2>/dev/null
}

code_to_svg() {
  local code=$1
  if   [ "$code" -eq 0 ];  then echo "sun.svg"
  elif [ "$code" -le 2 ];  then echo "cloud-sun.svg"
  elif [ "$code" -le 48 ]; then echo "cloud.svg"
  elif [ "$code" -le 67 ]; then echo "rain.svg"
  elif [ "$code" -le 77 ]; then echo "snow.svg"
  elif [ "$code" -le 86 ]; then echo "rain.svg"
  else                          echo "storm.svg"
  fi
}

code_to_desc() {
  local code=$1
  if   [ "$code" -eq 0 ];  then echo "Clear"
  elif [ "$code" -le 2 ];  then echo "Partly Cloudy"
  elif [ "$code" -le 3 ];  then echo "Overcast"
  elif [ "$code" -le 48 ]; then echo "Fog"
  elif [ "$code" -le 57 ]; then echo "Drizzle"
  elif [ "$code" -le 67 ]; then echo "Rain"
  elif [ "$code" -le 77 ]; then echo "Snow"
  elif [ "$code" -le 82 ]; then echo "Showers"
  elif [ "$code" -le 86 ]; then echo "Snow Showers"
  else                          echo "Thunderstorm"
  fi
}

get_temp() {
  local data temp
  data=$(read_data)
  temp=$(echo "$data" | jq -r '.current_weather.temperature // empty' 2>/dev/null | cut -d. -f1)
  if [ -n "$temp" ]; then
    echo "$temp"
  else
    echo "?"
  fi
}

get_svg() {
  local data code
  data=$(read_data)
  code=$(echo "$data" | jq -r '.current_weather.weathercode // empty' 2>/dev/null)
  if [ -n "$code" ]; then
    code_to_svg "$code"
  else
    echo "sun.svg"
  fi
}

get_full() {
  local data temp code desc hi lo rain
  data=$(read_data)
  temp=$(echo "$data" | jq -r '.current_weather.temperature // empty' 2>/dev/null | cut -d. -f1)
  code=$(echo "$data" | jq -r '.current_weather.weathercode // empty' 2>/dev/null)
  hi=$(echo "$data" | jq -r '.daily.temperature_2m_max[0] // empty' 2>/dev/null | cut -d. -f1)
  lo=$(echo "$data" | jq -r '.daily.temperature_2m_min[0] // empty' 2>/dev/null | cut -d. -f1)
  rain=$(echo "$data" | jq -r '.daily.precipitation_sum[0] // empty' 2>/dev/null | cut -d. -f1)
  desc=$(code_to_desc "${code:-0}")
  printf '%s %sC\nHigh: %sC  Low: %sC\nRain: %smm\nLocation: %s\n' "$desc" "${temp:-?}" "${hi:-?}" "${lo:-?}" "${rain:-?}" "$LOCATION"
}

case "$1" in
  --svg) get_svg ;;
  --tooltip|--full) get_full ;;
  *) get_temp ;;
esac
