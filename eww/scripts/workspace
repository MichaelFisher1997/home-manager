#!/usr/bin/env bash
# Rainbow workspace script for Hyprland - each workspace has unique color

resolve_hyprctl_json_field() {
    local json="$1"
    local filter="$2"

    if [ -z "$json" ]; then
        return 1
    fi

    if ! printf "%s" "$json" | jq -e '.[0]' >/dev/null 2>&1; then
        return 1
    fi

    local value
    value="$(printf "%s" "$json" | jq -r "$filter" 2>/dev/null | head -n1)"

    if [ -z "$value" ] || [ "$value" = "null" ]; then
        return 1
    fi

    printf "%s" "$value"
}

workspaces() {
    local monitor_json
    local occupied_json
    local active_ws
    local occupied_workspaces

    if ! command -v hyprctl >/dev/null 2>&1; then
        printf '%s\n' '(label :class "works" :text "No hyprctl")'
        return
    fi

    if ! command -v jq >/dev/null 2>&1; then
        printf '%s\n' '(label :class "works" :text "No jq")'
        return
    fi

    monitor_json="$(hyprctl -j monitors 2>/dev/null || hyprctl monitors -j 2>/dev/null || true)"
    active_ws="$(resolve_hyprctl_json_field "$monitor_json" '.[] | select(.focused) | .activeWorkspace.id')" || true

    if [ -z "$active_ws" ]; then
        printf '%s\n' '(label :class "works" :text "No workspace")'
        return
    fi

    occupied_json="$(hyprctl workspaces -j 2>/dev/null || true)"
    if printf "%s" "$occupied_json" | jq -e '.[0]' >/dev/null 2>&1; then
        # Get all occupied workspaces across ALL monitors
        occupied_workspaces="$(printf "%s" "$occupied_json" | jq -r '.[] | .id' 2>/dev/null | sort -n)"
    else
        occupied_workspaces=""
    fi
    
    # Start building the box
    output="(box :class \"works\" :orientation \"h\" :spacing 12 :space-evenly \"false\""
    
    # Add current workspace even if empty (so user knows where they are)
    current_in_list=false
    
    # Generate buttons for each occupied workspace
    while IFS= read -r ws_id; do
        if [ -n "$ws_id" ]; then
            # Check if this is the focused workspace
            if [ "$ws_id" -eq "$active_ws" ]; then
                # Active: filled circle with workspace-specific color
                icon="ď„‘"
                class="ws-${ws_id}-active"
                current_in_list=true
            else
                # Occupied: outlined circle with workspace-specific color
                icon="ď„Ś"
                class="ws-${ws_id}"
            fi
            
            output="$output (button :onclick \"hyprctl dispatch workspace $ws_id\" :class \"$class workspace-btn\" \"$icon\")"
        fi
    done <<< "$occupied_workspaces"
    
    # If current workspace is not in the occupied list (empty workspace), add it
    if [ "$current_in_list" = false ]; then
        output="$output (button :onclick \"hyprctl dispatch workspace $active_ws\" :class \"ws-${active_ws}-active workspace-btn\" \"ď„‘\")"
    fi
    
    # Close the box
    output="$output)"
    
    echo "$output"
}

workspaces

# Listen for workspace changes
if command -v socat >/dev/null 2>&1; then
    socket_path="/tmp/hypr/${HYPRLAND_INSTANCE_SIGNATURE}/.socket2.sock"
    if [ -S "$socket_path" ]; then
        socat -u UNIX-CONNECT:"$socket_path" - | while read -r _ ; do
            workspaces
        done
    else
        # Fallback to faster polling (100ms)
        while true; do
            sleep 0.1
            workspaces
        done
    fi
else
    # Fast polling mode (100ms) - install socat for instant updates
    while true; do
        sleep 0.1
        workspaces
    done
fi
