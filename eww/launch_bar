#!/usr/bin/env bash

set -euo pipefail

FILE="$HOME/.cache/eww_launch.xyz"
CONFIG_DIR="$HOME/.config/eww"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

log_info() { echo -e "${GREEN}[INFO]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }

if ! command -v eww &> /dev/null; then
    log_error "eww is not installed or not in PATH"
    exit 1
fi

eww_cmd() {
    eww --config "$CONFIG_DIR" "$@"
}

refresh_bar_state() {
    (
        eww_cmd poll volume_percent volume_mute volume_class volume_icon_glyph \
          brightness_percent battery battery_status memory memory_used_mb \
          memory_total_mb memory_free_mb COL_WLAN ESSID_WLAN WLAN_ICON \
          song song_summary song_artist current_status song_status cover_art \
          cpu_usage disk_usage disk_used disk_total weather weather_svg \
          weather_icon_path >/dev/null 2>&1 || true
    ) &
}

wait_for_daemon() {
    log_info "Waiting for eww daemon to be ready..."
    for i in {1..20}; do
        if eww_cmd ping &> /dev/null; then
            log_info "Daemon is ready!"
            return 0
        fi
        sleep 0.2
    done
    log_error "Daemon failed to start"
    return 1
}

start_daemon() {
    log_info "Starting eww daemon..."
    cd "$CONFIG_DIR"
    eww_cmd daemon --restart &

    wait_for_daemon
}

start_bar() {
    log_info "Starting eww bar..."

    start_daemon
    eww_cmd close-all >/dev/null 2>&1 || true

    touch "$FILE"

    log_info "Opening bar widget..."
    if eww_cmd open bar; then
        refresh_bar_state
        log_info "Bar started successfully!"
    else
        log_error "Failed to open bar"
        rm -f "$FILE"
        exit 1
    fi
}

stop_bar() {
    log_info "Stopping eww bar..."

    if eww_cmd ping &> /dev/null; then
        eww_cmd close-all 2>/dev/null || true
        log_info "Windows closed"
    fi
    rm -f "$FILE"

    log_info "Bar stopped successfully!"
}

toggle_bar() {
    if eww_cmd active-windows 2>/dev/null | grep -q '^bar:'; then
        stop_bar
    else
        start_bar
    fi
}

case "${1:-toggle}" in
    start)
        start_bar
        ;;
    stop)
        stop_bar
        ;;
    toggle)
        toggle_bar
        ;;
    *)
        log_error "Usage: $0 [start|stop|toggle]"
        exit 1
        ;;
esac
