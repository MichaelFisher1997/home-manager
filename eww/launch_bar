#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}"
FILE="$CACHE_DIR/eww_launch.xyz"
CONFIG_DIR="${EWW_CONFIG_DIR:-$SCRIPT_DIR}"

if [ ! -d "$CONFIG_DIR" ]; then
    echo "[ERROR] Eww config directory not found: $CONFIG_DIR"
    exit 1
fi

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

log_info() { echo -e "${GREEN}[INFO]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }

if ! command -v eww &> /dev/null; then
    log_error "eww is not installed or not in PATH"
    exit 1
fi

resolve_monitor_from_hyprctl_json() {
    local json="$1"

    if [ -z "$json" ]; then
        return 1
    fi

    if ! echo "$json" | jq -e '.[0]' >/dev/null 2>&1; then
        return 1
    fi

    local focused
    focused="$(echo "$json" | jq -r '.[] | select(.focused == true) | .name' | head -n1)"
    if [ -z "$focused" ] || [ "$focused" = "null" ]; then
        focused="$(echo "$json" | jq -r '.[] | .name' | head -n1)"
    fi

    if [ -n "$focused" ] && [ "$focused" != "null" ]; then
        printf "%s" "$focused"
        return 0
    fi

    return 1
}

resolve_monitor_from_hyprctl_text() {
    local text="$1"

    if [ -z "$text" ]; then
        return 1
    fi

    # Typical output: "Monitor eDP-1 (ID 0):"
    local text_monitor
    text_monitor="$(printf "%s" "$text" | awk '/^Monitor / {print $2; exit}')"

    if [ -n "$text_monitor" ]; then
        printf "%s" "$text_monitor"
        return 0
    fi

    return 1
}

detect_monitor() {
    local monitor="DP-1"
    local hypr_json
    local hypr_text
    local host_monitor_map
    local hostname

    if [ -n "${EWW_TARGET_MONITOR:-}" ]; then
        monitor="$EWW_TARGET_MONITOR"
        printf '%s\n' "$monitor"
        return 0
    fi

    if command -v hyprctl >/dev/null 2>&1; then
        if command -v jq >/dev/null 2>&1; then
            hypr_json="$(hyprctl -j monitors 2>/dev/null || true)"
            if monitor="$(resolve_monitor_from_hyprctl_json "$hypr_json")"; then
                printf '%s\n' "$monitor"
                return 0
            fi

            hypr_json="$(hyprctl monitors -j 2>/dev/null || true)"
            if monitor="$(resolve_monitor_from_hyprctl_json "$hypr_json")"; then
                printf '%s\n' "$monitor"
                return 0
            fi
        fi

        hypr_text="$(hyprctl monitors 2>/dev/null || true)"
        if monitor="$(resolve_monitor_from_hyprctl_text "$hypr_text")"; then
            printf '%s\n' "$monitor"
            return 0
        fi
    fi

    host_monitor_map="${MONITOR_MAP:-}"
    hostname="$(hostname 2>/dev/null || cat /etc/hostname 2>/dev/null || printf 'desktop')"

    case "$hostname" in
      hyprtop|laptop) monitor="eDP-1" ;;
      *) monitor="DP-1" ;;
    esac

    if [ -n "$host_monitor_map" ]; then
        monitor="$(printf '%s' "$host_monitor_map" | awk -F= -v host="$hostname" '$1 == host { print $2; exit }')"
    fi

    if [ -z "$monitor" ] || [ "$monitor" = "null" ]; then
        monitor="DP-1"
    fi

    printf '%s\n' "$monitor"
}

prepare_eww_config() {
    local monitor="$1"
    local source_yuck="$CONFIG_DIR/eww.yuck"
    ACTIVE_CONFIG_DIR="$CONFIG_DIR"

    if [ "$monitor" = "DP-1" ]; then
        return 0
    fi

    if [ ! -f "$source_yuck" ]; then
        log_error "eww config file missing: $source_yuck"
        exit 1
    fi

    ACTIVE_CONFIG_DIR="$CACHE_DIR/eww/config-${monitor}"
    rm -rf "$ACTIVE_CONFIG_DIR"
    mkdir -p "$ACTIVE_CONFIG_DIR"
    cp -a "$CONFIG_DIR/." "$ACTIVE_CONFIG_DIR/"
    sed -i "s/\"DP-1\"/\"$monitor\"/g" "$ACTIVE_CONFIG_DIR/eww.yuck"
}

eww_cmd() {
    eww --config "$ACTIVE_CONFIG_DIR" "$@"
}

kill_eww() {
    if ! pgrep -x "eww" > /dev/null 2>&1; then
        return 0
    fi

    killall eww 2>/dev/null || true
    sleep 0.5

    if pgrep -x "eww" > /dev/null 2>&1; then
        log_warn "Daemon didn't respond to SIGTERM, sending SIGKILL..."
        killall -9 eww 2>/dev/null || true
        sleep 0.5
    fi

    if pgrep -x "eww" > /dev/null 2>&1; then
        log_error "Failed to kill eww processes"
        return 1
    fi
}

wait_for_daemon() {
    log_info "Waiting for eww daemon to be ready..."
    for i in {1..20}; do
        if eww_cmd ping &> /dev/null; then
            log_info "Daemon is ready!"
            return 0
        fi
        sleep 0.2
    done
    log_error "Daemon failed to start"
    return 1
}

start_daemon() {
    if eww_cmd ping &> /dev/null; then
        log_warn "Eww daemon already running, killing it..."
        kill_eww
    elif pgrep -x "eww" > /dev/null 2>&1; then
        log_warn "Stale eww process found, cleaning up..."
        kill_eww
    fi
    
    log_info "Starting eww daemon..."
    cd "$ACTIVE_CONFIG_DIR"
    eww --config "$ACTIVE_CONFIG_DIR" daemon &
    sleep 1

    wait_for_daemon
}

if [[ ! -f "$FILE" ]]; then
    mkdir -p "$CACHE_DIR"
    TARGET_MONITOR="${EWW_TARGET_MONITOR:-$(detect_monitor)}"
    prepare_eww_config "$TARGET_MONITOR"

    log_info "Starting eww bar..."

    start_daemon

    touch "$FILE"

    log_info "Opening bar widget..."
    if eww_cmd open bar; then
        log_info "Bar started successfully!"
    else
        log_error "Failed to open bar"
        rm -f "$FILE"
        exit 1
    fi
else
    log_info "Stopping eww bar..."
    mkdir -p "$CACHE_DIR"
    TARGET_MONITOR="${EWW_TARGET_MONITOR:-$(detect_monitor)}"
    prepare_eww_config "$TARGET_MONITOR"

    if eww_cmd ping &> /dev/null; then
        eww_cmd close-all 2>/dev/null || true
        log_info "Windows closed"
    fi

    kill_eww
    rm -f "$FILE"

    log_info "Bar stopped successfully!"
fi
