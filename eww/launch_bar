#!/usr/bin/env bash

set -euo pipefail

FILE="$HOME/.cache/eww_launch.xyz"
CONFIG_DIR="$HOME/.config/eww"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

log_info() { echo -e "${GREEN}[INFO]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }

if ! command -v eww &> /dev/null; then
    log_error "eww is not installed or not in PATH"
    exit 1
fi

eww_cmd() {
    eww --config "$CONFIG_DIR" "$@"
}

is_bar_open() {
    eww_cmd active-windows 2>/dev/null | grep -q '^bar:'
}

kill_eww() {
    if ! pgrep -x "eww" > /dev/null 2>&1; then
        return 0
    fi

    killall eww 2>/dev/null || true
    sleep 0.5

    if pgrep -x "eww" > /dev/null 2>&1; then
        log_warn "Daemon didn't respond to SIGTERM, sending SIGKILL..."
        killall -9 eww 2>/dev/null || true
        sleep 0.5
    fi

    if pgrep -x "eww" > /dev/null 2>&1; then
        log_error "Failed to kill eww processes"
        return 1
    fi
}

wait_for_daemon() {
    log_info "Waiting for eww daemon to be ready..."
    for i in {1..20}; do
        if eww_cmd ping &> /dev/null; then
            log_info "Daemon is ready!"
            return 0
        fi
        sleep 0.2
    done
    log_error "Daemon failed to start"
    return 1
}

start_daemon() {
    if eww_cmd ping &> /dev/null || pgrep -x "eww" > /dev/null 2>&1; then
        log_warn "Existing eww state found, restarting daemon..."
        kill_eww
    fi

    log_info "Starting eww daemon..."
    cd "$CONFIG_DIR"
    eww_cmd daemon &

    wait_for_daemon
}

start_bar() {
    log_info "Starting eww bar..."

    if is_bar_open; then
        log_info "Bar is already open"
        touch "$FILE"
        return 0
    fi

    start_daemon

    touch "$FILE"

    log_info "Opening bar widget..."
    if eww_cmd open bar; then
        log_info "Bar started successfully!"
    else
        log_error "Failed to open bar"
        rm -f "$FILE"
        exit 1
    fi
}

stop_bar() {
    log_info "Stopping eww bar..."

    if eww_cmd ping &> /dev/null && is_bar_open; then
        eww_cmd close bar 2>/dev/null || true
    fi

    if eww_cmd ping &> /dev/null; then
        eww_cmd close-all 2>/dev/null || true
        log_info "Windows closed"
    fi

    kill_eww
    rm -f "$FILE"

    log_info "Bar stopped successfully!"
}

toggle_bar() {
    if is_bar_open; then
        stop_bar
    else
        start_bar
    fi
}

case "${1:-toggle}" in
    start)
        start_bar
        ;;
    stop)
        stop_bar
        ;;
    toggle)
        toggle_bar
        ;;
    *)
        log_error "Usage: $0 [start|stop|toggle]"
        exit 1
        ;;
esac
